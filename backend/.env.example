PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/dealer-payment
JWT_SECRET=supersecretjwtkeyforaccess123456
JWT_REFRESH_SECRET=supersecretjwtrefreshkeyforauth987654

# SMTP Email Configuration (Nodemailer)
# If left empty, emails and OTPs will be printed to the terminal console for easy testing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=5857
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Dealer Payments" <your_email@gmail.com>

# Initial Admin Credentials (used by seed script)
ADMIN_INITIAL_EMAIL=admin@dealer.com
ADMIN_INITIAL_PHONE=9876543210
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=AdminPassword123

FRONTEND_URL=http://localhost:5173
